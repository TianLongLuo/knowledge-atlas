ENVIRONMENT=development
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=knowledge_atlas
CHROMA_DATA_PATH=./data/chroma
CHROMA_COLLECTION_NAME=knowledge_atlas

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
# Generate with the command documented in the root README.
ADMIN_PASSWORD_HASH=''
SESSION_COOKIE_SECURE=false

CORS_ORIGINS=["http://localhost:3000"]
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_AUTO_SYNC_ENABLED=true
NOTION_AUTO_SYNC_INTERVAL_MINUTES=60
NOTION_WRITEBACK_DEBOUNCE_SECONDS=3
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# Keep this value out of source control. Restart the backend after changing it.
DEEPSEEK_TIMEOUT_SECONDS=45
# Automatic memory learns from saved notes and the user's own chat messages.
# Inferred patterns remain tentative; only direct high-confidence statements
# become trusted facts automatically.
MEMORY_AUTOMATION_ENABLED=true
MEMORY_EXTRACTION_DEBOUNCE_SECONDS=12
MEMORY_PROFILE_INTERVAL_MINUTES=360
EMBEDDING_MODEL=all-MiniLM-L6-v2

GRAPH_DEFAULT_LIMIT=180
GRAPH_NEIGHBORS_PER_NODE=6
GRAPH_MAX_EDGES=450
